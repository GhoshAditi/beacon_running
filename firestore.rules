rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function myCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
      allow create: if !isSignedIn(); // Allow seed script
    }

    // COMPANIES
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // EMAILS
    // FIX: added isAdmin() bypass so the admin dashboard can read across all companies.
    match /emails/{emailId} {
      allow create: if isSignedIn() && (request.resource.data.companyId == myCompanyId() || isAdmin());
      allow read: if isSignedIn() && (resource.data.companyId == myCompanyId() || isAdmin());
      allow update, delete: if false; // Logs/emails are immutable once created.
    }

    // ACCESS & BEACON LOGS
    match /{collection}/{logId} {
      allow create: if true; // Secure link page is unauthenticated.
      allow read: if isSignedIn() &&
                    (resource.data.companyId == myCompanyId() || isAdmin()) &&
                    (collection == 'accessLogs' || collection == 'beaconLogs');
      allow update, delete: if false;
    }

    // ALERTS
    // FIX: previously only covered by the generic block above, which excluded 'alerts'.
    match /alerts/{alertId} {
      allow create: if true; // Created by server-side flows (admin SDK bypasses rules anyway).
      allow read: if isSignedIn() && (resource.data.companyId == myCompanyId() || isAdmin());
      allow update: if isSignedIn() && (resource.data.companyId == myCompanyId() || isAdmin());
      allow delete: if false;
    }

    // PIN RESET REQUESTS
    // FIX: previously had no rule at all — always denied.
    match /pinResetRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.companyId == myCompanyId() || isAdmin());
      allow update: if isSignedIn() && (resource.data.companyId == myCompanyId() || isAdmin());
      allow delete: if false;
    }
  }
}